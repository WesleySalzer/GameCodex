{
  "name": "@gamecodex/tui",
  "version": "0.1.0",
  "description": "GameCodex TUI — AI-powered game dev assistant in your terminal",
  "type": "module",
  "main": "src/index.tsx",
  "bin": {
    "gamecodex": "./bin/gamecodex.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.tsx",
    "build": "tsc",
    "start": "tsx src/index.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/openai": "^3.0.49",
    "@ai-sdk/openai-compatible": "^1.0.0",
    "@ai-sdk/google": "^3.0.55",
    "ai": "^6.0.142",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.24.4",
    "gradient-string": "^2.0.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
