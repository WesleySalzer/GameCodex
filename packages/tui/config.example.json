{
  "providers": {
    "ollama": {
      "baseURL": "http://localhost:11434/v1",
      "defaultModel": "llama3.2"
    },
    "anthropic": {
      "apiKey": "env:ANTHROPIC_API_KEY"
    }
  },
  "tui": {
    "defaultProvider": "ollama",
    "showToolCalls": true,
    "autoRecover": true,
    "maxIterations": 50,
    "serverPath": "../server/dist/server.js"
  }
}
