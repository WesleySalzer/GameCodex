{
  "name": "gamecodex-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "GameCodex — Game dev AI assistant. Monorepo for the MCP server and marketing site.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=gamecodex",
    "build:site": "npm run build --workspace=@gamecodex/site",
    "build:all": "npm run build --workspaces",
    "dev": "npm run dev --workspace=gamecodex",
    "dev:site": "npm run dev --workspace=@gamecodex/site",
    "start": "npm run start --workspace=gamecodex",
    "typecheck": "npm run typecheck --workspace=gamecodex",
    "test": "npm run test --workspace=gamecodex",
    "lint:site": "npm run lint --workspace=@gamecodex/site",
    "dev:tui": "npm run dev --workspace=@gamecodex/tui",
    "build:tui": "npm run build --workspace=@gamecodex/tui",
    "start:tui": "npm run start --workspace=@gamecodex/tui"
  },
  "author": "shawn-benson",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
